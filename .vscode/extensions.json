{
    "recommendations": [
        // STM32 toolchain
        "stmicroelectronics.stm32vscode", // STM32 VS Code extension (drives CubeCLT integration)
        "marus25.cortex-debug", // Debug support for Arm Cortex-M
        "mcu-debug.debug-tracker-vscode", // Dependency of cortex-debug
        "mcu-debug.memory-view", // Dependency of cortex-debug
        "mcu-debug.peripheral-viewer", // Dependency of cortex-debug
        "mcu-debug.rtos-views", // Dependency of cortex-debug
        // C/C++ and CMake
        "ms-vscode.cpptools-extension-pack", // C++, CMake tools, themes
        "llvm-vs-code-extensions.vscode-clangd", // Clangd language server (configured in settings.json)
        // Syntax support
        "dan-c-underwood.arm", // Arm Assembly syntax highlighting
        "zixuanwang.linkerscript", // Linker script syntax highlighting
        "ms-vscode.hexeditor", // Hex editor for binary/firmware files
        "trond-snekvik.gnu-mapfiles", // GNU linker .map file support
        "jeff-hykin.better-cpp-syntax", // Improved C++ syntax highlighting
        // Remote development (for Raspberry Pi 5 onboard computer)
        "ms-vscode-remote.remote-ssh" // SSH into RPi5 to develop/flash from it
    ]
}