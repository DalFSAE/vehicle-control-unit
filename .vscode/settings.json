        "stm32f4xx_hal.h": "c",
        "gpio.h": "c",
        "sensor_input.h": "c",
        "cmsis_os.h": "c",
        "adc.h": "c",
        "cmsis_os2.h": "c",
        "dma.h": "c",
        "stdio.h": "c",
        "compare": "c",
        "freertos.h": "c",
        "stdbool.h": "c",
        "sensor_control.h": "c",
        "usbd_cdc_if.h": "c",
        "string.h": "c",
        "usbd_def.h": "c",
        "usbd_conf.h": "c",
        "io_control.h": "c",
        "tests.h": "c",
        "dms_defines.h": "c",
        "dms_logging.h": "c",
        "xutility": "c",
        "math.h": "c"
